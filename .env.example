# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 调试模式
DEBUG=true

# 邮件配置（可选）
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=465
EMAIL_USERNAME=your@email.com
EMAIL_PASSWORD=your_password
EMAIL_TO=receiver@email.com

# 企业微信配置（可选）
WECOM_ENABLED=false
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
